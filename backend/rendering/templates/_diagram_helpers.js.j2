// ── Diagram Intelligence Variables ──────────────────────────
let diagramImgEl = document.getElementById('diagram-img');
let diagramImgW = 0;
let diagramImgH = 0;
let diagramPanelRect = null;
let annotationSVG = document.getElementById('annotation-svg');
let cursorDot = document.getElementById('cursor-dot');

function initDiagramCoords() {
  if (!diagramImgEl) return;
  diagramImgW = diagramImgEl.naturalWidth || diagramImgEl.offsetWidth;
  diagramImgH = diagramImgEl.naturalHeight || diagramImgEl.offsetHeight;
  diagramPanelRect = diagramImgEl.getBoundingClientRect();
}

function regionToPixels(region) {
  if (!diagramImgEl) diagramImgEl = document.getElementById('diagram-img');
  if (!diagramImgEl) return { x: 0, y: 0, w: 0, h: 0, cx: 0, cy: 0 };
  
  const r = diagramImgEl.getBoundingClientRect();
  const stage = document.getElementById('diag-stage') || document.getElementById('diagram-card') || document.getElementById('right-panel') || document.body;
  const stageRect = stage.getBoundingClientRect();
  
  const offsetX = r.left - stageRect.left;
  const offsetY = r.top - stageRect.top;
  
  return {
    x: offsetX + region.x_pct * r.width,
    y: offsetY + region.y_pct * r.height,
    w: region.w_pct * r.width,
    h: region.h_pct * r.height,
    cx: offsetX + (region.x_pct + region.w_pct / 2) * r.width,
    cy: offsetY + (region.y_pct + region.h_pct / 2) * r.height
  };
}

function zoomToRegion(region, scale, durationSec) {
  const wrapper = document.getElementById('diagram-zoom-wrapper') || document.getElementById('diagram-viewport');
  if (!wrapper) return;
  
  if (!diagramImgEl) diagramImgEl = document.getElementById('diagram-img');
  if (!diagramImgEl) return;
  
  const imgRect = diagramImgEl.getBoundingClientRect();
  const regionCX = (region.x_pct + region.w_pct / 2) * imgRect.width;
  const regionCY = (region.y_pct + region.h_pct / 2) * imgRect.height;
  const imgCX = imgRect.width / 2;
  const imgCY = imgRect.height / 2;
  
  if (typeof gsap !== 'undefined') {
      gsap.to(wrapper, {
        scale: scale,
        x: (imgCX - regionCX) * scale,
        y: (imgCY - regionCY) * scale,
        duration: durationSec || 0.9,
        ease: 'power3.inOut'
      });
  }
}

function zoomOut(durationSec) {
  const wrapper = document.getElementById('diagram-zoom-wrapper') || document.getElementById('diagram-viewport');
  if (!wrapper) return;
  if (typeof gsap !== 'undefined') {
      gsap.to(wrapper, { scale: 1, x: 0, y: 0, duration: durationSec || 0.8, ease: 'power2.inOut' });
  }
}

function drawCircleAnnotation(region, color) {
  if (!annotationSVG) annotationSVG = document.getElementById('diagram-svg-overlay') || document.getElementById('annotation-svg');
  if (!annotationSVG) return;
  
  if (!diagramImgEl) diagramImgEl = document.getElementById('diagram-img');
  if (!diagramImgEl) return;
  
  const imgRect = diagramImgEl.getBoundingClientRect();
  const svgRect = annotationSVG.getBoundingClientRect();
  const offsetX = imgRect.left - svgRect.left;
  const offsetY = imgRect.top  - svgRect.top;
  const cx = offsetX + (region.x_pct + region.w_pct/2) * imgRect.width;
  const cy = offsetY + (region.y_pct + region.h_pct/2) * imgRect.height;
  const rx = region.w_pct * imgRect.width / 2 + 10;
  const ry = region.h_pct * imgRect.height / 2 + 10;
  
  const circ = document.createElementNS('http://www.w3.org/2000/svg','ellipse');
  circ.setAttribute('cx', cx); circ.setAttribute('cy', cy);
  circ.setAttribute('rx', rx); circ.setAttribute('ry', ry);
  circ.setAttribute('fill','none');
  circ.setAttribute('stroke', color || '#00E5FF');
  circ.setAttribute('stroke-width','3');
  circ.setAttribute('opacity','0');
  
  const perim = 2 * Math.PI * Math.sqrt((rx*rx+ry*ry)/2);
  circ.setAttribute('stroke-dasharray', perim);
  circ.setAttribute('stroke-dashoffset', perim);
  annotationSVG.appendChild(circ);
  
  if (typeof gsap !== 'undefined') {
      gsap.to(circ, { opacity:1, strokeDashoffset:0, duration:1.3, ease:'power2.out' });
      setTimeout(() => { gsap.to(circ, { opacity:0, duration:0.4, onComplete:()=>circ.remove() }); }, 4000);
  }
}

function drawHighlightBox(region, color) {
  if (!annotationSVG) annotationSVG = document.getElementById('diagram-svg-overlay') || document.getElementById('annotation-svg');
  if (!annotationSVG) return;
  
  if (!diagramImgEl) diagramImgEl = document.getElementById('diagram-img');
  if (!diagramImgEl) return;
  
  const imgRect = diagramImgEl.getBoundingClientRect();
  const svgRect = annotationSVG.getBoundingClientRect();
  const x = (imgRect.left - svgRect.left) + region.x_pct * imgRect.width - 6;
  const y = (imgRect.top  - svgRect.top)  + region.y_pct * imgRect.height - 6;
  const w = region.w_pct * imgRect.width + 12;
  const h = region.h_pct * imgRect.height + 12;
  
  const rect = document.createElementNS('http://www.w3.org/2000/svg','rect');
  rect.setAttribute('x',x); rect.setAttribute('y',y);
  rect.setAttribute('width',w); rect.setAttribute('height',h);
  rect.setAttribute('rx','6'); rect.setAttribute('fill', color+'22' || '#FF444422');
  rect.setAttribute('stroke', color || '#FF4444');
  rect.setAttribute('stroke-width','2.5');
  rect.setAttribute('opacity','0');
  annotationSVG.appendChild(rect);
  
  if (typeof gsap !== 'undefined') {
      gsap.to(rect, { opacity:1, duration:0.4, ease:'power2.out',
        onComplete: () => gsap.to(rect, { opacity:1, yoyo:true, repeat:1, duration:0.5, delay:0.8,
          onComplete: () => setTimeout(()=>{ gsap.to(rect,{opacity:0,duration:0.4,onComplete:()=>rect.remove()})},3000) }) });
  }
}

function drawFlowArrow(fromRegion, toRegion, label, color) {
  if (!annotationSVG) annotationSVG = document.getElementById('diagram-svg-overlay') || document.getElementById('annotation-svg');
  if (!annotationSVG) return;
  
  if (!diagramImgEl) diagramImgEl = document.getElementById('diagram-img');
  if (!diagramImgEl) return;
  
  const imgRect = diagramImgEl.getBoundingClientRect();
  const svgRect = annotationSVG.getBoundingClientRect();
  const ox = imgRect.left - svgRect.left;
  const oy = imgRect.top  - svgRect.top;
  const x1 = ox + (fromRegion.x_pct + fromRegion.w_pct) * imgRect.width;
  const y1 = oy + (fromRegion.y_pct + fromRegion.h_pct/2) * imgRect.height;
  const x2 = ox + toRegion.x_pct * imgRect.width;
  const y2 = oy + (toRegion.y_pct + toRegion.h_pct/2) * imgRect.height;
  const arrowColor = color || '#FFD700';
  const markerId = 'arr_' + Date.now();
  
  let defs = annotationSVG.querySelector('defs');
  if (!defs) {
      defs = document.createElementNS('http://www.w3.org/2000/svg','defs');
      annotationSVG.insertBefore(defs, annotationSVG.firstChild);
  }
  defs.innerHTML += `<marker id="${markerId}" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto"><path d="M2 1L8 5L2 9" fill="none" stroke="${arrowColor}" stroke-width="1.5" stroke-linecap="round"/></marker>`;
  
  const pathLen = Math.sqrt((x2-x1)**2+(y2-y1)**2);
  const line = document.createElementNS('http://www.w3.org/2000/svg','line');
  line.setAttribute('x1',x1); line.setAttribute('y1',y1);
  line.setAttribute('x2',x2); line.setAttribute('y2',y2);
  line.setAttribute('stroke',arrowColor); line.setAttribute('stroke-width','3');
  line.setAttribute('marker-end',`url(#${markerId})`);
  line.setAttribute('stroke-dasharray',pathLen); line.setAttribute('stroke-dashoffset',pathLen);
  line.setAttribute('opacity','0');
  annotationSVG.appendChild(line);
  
  if (typeof gsap !== 'undefined') {
      gsap.to(line, { opacity:1, strokeDashoffset:0, duration:0.8, ease:'power2.inOut' });
      if (label) {
        const txt = document.createElementNS('http://www.w3.org/2000/svg','text');
        txt.setAttribute('x',(x1+x2)/2); txt.setAttribute('y',(y1+y2)/2 - 10);
        txt.setAttribute('text-anchor','middle'); txt.setAttribute('fill',arrowColor);
        txt.setAttribute('font-size','13'); txt.setAttribute('opacity','0');
        txt.textContent = label;
        annotationSVG.appendChild(txt);
        gsap.to(txt, { opacity:1, duration:0.4, delay:0.7 });
      }
      setTimeout(()=>{ gsap.to([line], { opacity:0, duration:0.4, onComplete:()=>{ line.remove(); } }) }, 5000);
  }
}

function moveCursor(region) {
  if (!cursorDot) cursorDot = document.getElementById('cursor-dot');
  const stage = document.getElementById('diag-stage') || document.getElementById('diagram-card') || document.getElementById('right-panel') || document.body;
  if (!cursorDot) {
      cursorDot = document.createElement('div');
      cursorDot.id = 'cursor-dot';
      cursorDot.style.position = 'absolute';
      cursorDot.style.width = '18px';
      cursorDot.style.height = '18px';
      cursorDot.style.zIndex = '200';
      cursorDot.style.background = 'rgba(0, 229, 255, 0.9)';
      cursorDot.style.boxShadow = '0 0 12px 6px rgba(0, 229, 255, 0.5)';
      cursorDot.style.borderRadius = '50%';
      cursorDot.style.pointerEvents = 'none';
      cursorDot.style.opacity = '0';
      cursorDot.style.transform = 'translate(-50%, -50%)';
      stage.appendChild(cursorDot);
  }
  
  if (!diagramImgEl) diagramImgEl = document.getElementById('diagram-img');
  if (!diagramImgEl) return;
  
  const imgRect = diagramImgEl.getBoundingClientRect();
  const stageRect = stage.getBoundingClientRect();
  
  const cx = (imgRect.left - stageRect.left) + (region.x_pct + region.w_pct / 2) * imgRect.width;
  const cy = (imgRect.top - stageRect.top) + (region.y_pct + region.h_pct / 2) * imgRect.height;
  
  if (typeof gsap !== 'undefined') {
      if (parseFloat(cursorDot.style.opacity||0) === 0) {
        gsap.set(cursorDot, { left: cx, top: cy, opacity: 0.8 });
      } else {
        gsap.to(cursorDot, { left: cx, top: cy, opacity: 0.8, duration: 0.65, ease: 'power2.inOut' });
      }
      gsap.fromTo(cursorDot, { scale: 1 }, { scale: 1.8, duration: 0.3, ease: 'power2.out',
        onComplete: () => gsap.to(cursorDot, { scale: 1, duration: 0.2 }) });
  }
}

function clearAnnotations() {
  if (annotationSVG) {
    while (annotationSVG.lastChild && annotationSVG.lastChild.tagName !== 'defs') {
      annotationSVG.removeChild(annotationSVG.lastChild);
    }
  }
  if (cursorDot && typeof gsap !== 'undefined') gsap.to(cursorDot, { opacity:0, duration:0.3 });
}

document.addEventListener("DOMContentLoaded", () => {
    if (!diagramImgEl) diagramImgEl = document.getElementById('diagram-img');
    if (diagramImgEl) {
      diagramImgEl.onload = initDiagramCoords;
      if (diagramImgEl.complete) initDiagramCoords();
    }
});
